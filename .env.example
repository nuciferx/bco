TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
CHROME_PROFILE=Profile 3

# Optional direct-login fallback when Chrome token has expired.
# Use "backoffice" when the account can log in without OTP.
# Use "officer" together with BCO_TOTP_SECRET or BCO_OTP_CODE.
BCO_LOGIN_MODE=backoffice
BCO_USERNAME=
BCO_PASSWORD=
BCO_TOTP_SECRET=
BCO_OTP_CODE=
